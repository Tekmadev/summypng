# ─────────────────────────────────────────────────────────────────────────────
# SummyPNG: Environment variables (template)
#
# Copy this file to `.env.local` and fill in real values. Never commit secrets.
# Supabase wiring is DEFERRED in Phase 1. These keys are placeholders until the
# project is provisioned (owned by Shajeed). See SUMMYPNG_CLAUDE_CODE_BRIEF.md.
# ─────────────────────────────────────────────────────────────────────────────

# Public site origin, used for canonical URLs, sitemap, robots, OG tags.
NEXT_PUBLIC_SITE_URL=https://summysingh.com

# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Publishable (anon) key: safe to expose to the browser; RLS enforces access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret (service-role) key: SERVER ONLY. Bypasses RLS. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Email (inquiry notifications via Resend) ─────────────────────────────────
# API key from resend.com. If unset, inquiries still save to Supabase; only the
# email notification is skipped (the contact form still succeeds).
RESEND_API_KEY=
# Where inquiry notifications are delivered.
INQUIRY_NOTIFICATION_EMAIL=summy.png@gmail.com
# From address for notification emails. Until a domain is verified in Resend,
# leave unset to fall back to onboarding@resend.dev (delivers to the Resend
# account owner only). Once summysingh.com is verified, set e.g.
# RESEND_FROM="Summy Singh Photography <inquiries@summysingh.com>".
RESEND_FROM=
